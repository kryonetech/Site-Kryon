rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: block everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Leads collection:
    // Anyone can create a new lead (public form submission)
    // Only authenticated admins (future) can read/update/delete
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Restrict this further when roles are strictly implemented
    }

    // Projects collection:
    // Only authenticated users can manage projects
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    // Users collection:
    // Only authenticated users can view/manage
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId; // Or admin restrict
    }
  }
}
